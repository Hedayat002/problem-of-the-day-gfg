    def ShortestDistance(self, mat):
        """
        Parameters: mat[][] - nГ—n grid
        Returns:    nГ—n path matrix or [[-1]]
        
        Time:  O(nВІ Г— max_element)
        Space: O(1) extra (O(nВІ) for ans matrix)
        """
        n = len(mat)
        
        # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
        # в”Ӯ  Initialize result matrix   в”Ӯ
        # в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
        ans = [[0] * n for _ in range(n)]

        def backtrack(i, j):
            """
            Recursive function with pruning
            Returns True if path found from (i,j) to (n-1,n-1)
            """
            
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            # вң… BASE CASE: At destination
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            if i == n - 1 and j == n - 1:
                ans[i][j] = 1
                return True
            
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            # вқҢ INVALID: Out of bounds or blocked
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            if i >= n or j >= n or mat[i][j] == 0:
                return False
            
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            # рҹ“Ң MARK: Include cell in path
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            ans[i][j] = 1
            max_jump = mat[i][j]
            
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            # рҹ”Қ EXPLORE: All jumps, shortest first
            #             Right (j+k) before Down (i+k)
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            for k in range(1, max_jump + 1):
                
                # рҹ‘ү RIGHT: same row, next column
                if j + k < n:
                    if backtrack(i, j + k):
                        return True
                
                # рҹ‘Ү DOWN: next row, same column
                if i + k < n:
                    if backtrack(i + k, j):
                        return True
            
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            # рҹ”ҙ PRUNE: Dead end found
            #    - Remove from current path
            #    - Block permanently to avoid re-exploration
            # в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
            ans[i][j] = 0
            mat[i][j] = 0    # KEY OPTIMIZATION!
            return False

        # в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
        # в”Ӯ  Start backtracking from (0, 0)     в”Ӯ
        # в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
        if backtrack(0, 0):
            return ans
        else:
            return [[-1]]


# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
#                    TESTING
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

def print_matrix(matrix, title=""):
    print(f"\n{title}")
    print("в”Ң" + "в”Җв”Җв”Җв”Җв”Җв”¬" * (len(matrix[0])-1) + "в”Җв”Җв”Җв”Җв”Җв”җ")
    for i, row in enumerate(matrix):
        print("в”Ӯ " + " в”Ӯ ".join(f"  {v} " for v in row) + " в”Ӯ")
        if i < len(matrix)-1:
            print("в”ң" + "в”Җв”Җв”Җв”Җв”Җв”ј" * (len(row)-1) + "в”Җв”Җв”Җв”Җв”Җв”Ө")
    print("в””" + "в”Җв”Җв”Җв”Җв”Җв”ҙ" * (len(matrix[0])-1) + "в”Җв”Җв”Җв”Җв”Җв”ҳ")

def run_test(test_num, mat):
    print(f"\n{'в•җ'*55}")
    print(f"TEST CASE {test_num}")
    print(f"{'в•җ'*55}")
    
    # Deep copy for display (solution modifies mat)
    import copy
    mat_display = copy.deepcopy(mat)
    mat_solve   = copy.deepcopy(mat)
    
    print_matrix(mat_display, "INPUT MATRIX:")
    
    sol = Solution()
    result = sol.ShortestDistance(mat_solve)
    
    print_matrix(result, "OUTPUT (Path Matrix):")
    
    if result != [[-1]]:
        path = []
        for i in range(len(result)):
            for j in range(len(result[0])):
                if result[i][j] == 1:
                    path.append(f"({i},{j})")
        print(f"\nPath cells: {' вҶ’ '.join(path)}")
    else:
        print("\nNo valid path exists!")

# Test Case 1
mat1 = [[2, 1, 0, 0],
        [3, 0, 0, 1],
        [0, 1, 0, 1],
        [0, 0, 0, 1]]
run_test(1, mat1)

# Test Case 2
mat2 = [[2, 1, 0, 0],
        [2, 0, 0, 1],
        [0, 1, 0, 1],
        [0, 0, 0, 1]]
run_test(2, mat2)

# Test Case 3: Single cell
mat3 = [[1]]
run_test(3, mat3)
