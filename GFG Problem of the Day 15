class Solution:
    def maxSumSubarray(self, arr):
        n = len(arr)

        keep = arr[0]
        delete = float("-inf")

        ans = arr[0]

        for i in range(1, n):
            new_delete = max(keep, delete + arr[i])
            new_keep = max(arr[i], keep + arr[i])

            keep = new_keep
            delete = new_delete

            ans = max(ans, keep, delete)

        return ans


