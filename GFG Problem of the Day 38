# Optimal Code

```python
class Solution:

    def solve(self, node):

        if node is None:
            return 0

        left = self.solve(node.left)
        right = self.solve(node.right)

        curr = 1

        if node.left and node.left.data == node.data + 1:
            curr = max(curr, left + 1)

        if node.right and node.right.data == node.data + 1:
            curr = max(curr, right + 1)

        self.ans = max(self.ans, curr)

        return curr

    def longestConsecutive(self, root):

        self.ans = 1

        self.solve(root)

        if self.ans == 1:
            return -1

        return self.ans
```

