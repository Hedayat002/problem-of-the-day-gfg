Code (Python)

class Solution:
    def waysToIncreaseLCSByOne(self, s1, s2):
        n = len(s1)
        m = len(s2)

        pre = [[0]*(m+1) for _ in range(n+1)]

        for i in range(1, n+1):
            for j in range(1, m+1):
                if s1[i-1] == s2[j-1]:
                    pre[i][j] = pre[i-1][j-1] + 1
                else:
                    pre[i][j] = max(pre[i-1][j], pre[i][j-1])

        suf = [[0]*(m+1) for _ in range(n+1)]

        for i in range(n-1, -1, -1):
            for j in range(m-1, -1, -1):
                if s1[i] == s2[j]:
                    suf[i][j] = 1 + suf[i+1][j+1]
                else:
                    suf[i][j] = max(suf[i+1][j], suf[i][j+1])

        lcs = pre[n][m]
        ans = 0

        for pos in range(n+1):
            used = set()

            for j in range(m):
                if pre[pos][j] + 1 + suf[pos][j+1] == lcs + 1:
                    used.add(s2[j])

            ans += len(used)

        return ans


